="48px" padding-bottom="12px" padding-left="48px"><mj-column><mj-text color="#222222" font-family="Helvetica, Arial, sans-serif" font-size="26px" line-height="30px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Build your wishlist together</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="48px" padding-bottom="32px" padding-left="48px"><mj-column><mj-text color="#6A6A6A" font-family="Helvetica, Arial, sans-serif" font-size="18px" line-height="28px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px">As you're exploring, create a list of places that catch your eye and invite others to vote, add notes, and more.</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-bottom="32px"><mj-column><mj-button background-color="#222222" border-radius="8px" color="#FFFFFF" font-family="Helvetica, Arial, sans-serif" font-size="18px" font-weight="500" line-height="1.3" inner-padding="16px 32px 16px 32px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" href="#">Start exploring</mj-button></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-bottom="0px"><mj-column><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="96px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/l999txvu_ccf11b0a-a5dc-4906-a9ad-d2bc0eacb2cf.png" alt="A large house with a bay window, tucked into rolling hills. Guest chat bubbles vote yes on the listing." width="600px"></mj-image></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="48px" padding-bottom="0px" padding-left="48px"><mj-column><mj-divider border-width="1px" border-colo