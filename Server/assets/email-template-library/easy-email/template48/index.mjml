<mjml>
  <mj-head>
       <mj-style>.mjbody a, .mjbody a:hover, .mjbody a:active, .mjbody a[href], .mjbody a[href]:hover, .mjbody a[href]:active {color: inherit;text-decoration: underline}</mj-style>
    <mj-breakpoint width="480px" />
  </mj-head>
  <mj-body width="580px" background-color="#F3F3F3" css-class="mjbody">
    <mj-section background-repeat="no-repeat" padding="20px 0" padding-top="48px" padding-right="16px" padding-bottom="16px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-image align="left" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/jg6ekntx_logo_standard_2x-c0ed1450d18490825bc37dd6cb23e5c5.png" alt="Airbnb" width="100px" href="https://www.airbnb.com"></mj-image></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="32px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="700">Your reservation is confirmed</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="16px" padding-left="0px" font-weight="300">You're going to San Francisco.</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="8px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/fglfwqm9_3a4e6241-7bd2-47e0-8f67-5c3c6e21d20a.jpg" alt="Listing Photo" width="548px" href="https://www.airbnb.com/"></mj-image></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column vertical-align="middle"><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">Superhosted Castro Studio. Easy Parking. No Keys.</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">Entire home/apt hosted by Christian</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-group><mj-column width="42%"><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">Tuesday,</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">Oct 24, 2017</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">Check in Anytime after 3PM</mj-text></mj-column><mj-column vertical-align="middle" width="16%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/h37acic6_slash-7e6cd0c69def410f055ffd703c08e140.png" width="40px"></mj-image></mj-column><mj-column width="42%"><mj-text align="right" color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">Friday,</mj-text><mj-text align="right" color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">OCT 27, 2017</mj-text><mj-text align="right" color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">Check out 11AM</mj-text></mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-button background-color="#FF5A5F" border-radius="4px" color="#FFFFFF" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" font-weight="400" line-height="32px" inner-padding="19px 24px 19px 24px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" href="https://www.airbnb.com" width="100%">View Full Itinerary</mj-button></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column width="60%"><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">Address</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">650 Street, San Francisco, CA 94114, United States</mj-text></mj-column><mj-column width="40%"><mj-text align="right" color="#FF5A5F" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300"><span><a href="https://www.airbnb.com">Get Directions</a></span></mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">Guests</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">1</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column width="60%"><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">Amount</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">$650.65</mj-text></mj-column><mj-column width="40%"><mj-text align="right" color="#FF5A5F" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300"><span><a href="https://www.airbnb.com">View Receipt</a></span></mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column width="60%"><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">Reservation Code</mj-text></mj-column><mj-column width="40%"><mj-text align="right" color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300">SMLSDVS</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-button background-color="#FEFEFE" border="1px solid #AAAAAA" border-radius="4px" color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" font-weight="400" line-height="32px" inner-padding="19px 24px 19px 24px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" href="https://www.airbnb.com" width="100%">Change Your Reservation</mj-button></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column width="85%"><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="700">Christian is your host</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="300">Contact Christian to coordinate arrival time and key exchange.</mj-text><mj-text color="#FF5A5F" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-left="0px" font-weight="300"><span><a href="https://www.airbnb.com">Message Host</a></span> •&nbsp;<span><a href="tel:+12345678910">+1 (234) 567-8910</a></span></mj-text></mj-column><mj-column width="15%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/3woostbru3adozviwv8qk_image.png" alt="Christian" width="77px" border-radius="50%" href="https://www.airbnb.com"></mj-image><mj-image padding="10px 25px" padding-top="4px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/idtyrh4k_5.0_stars-8b3a9b9fe0d1aa014b1f97859cd599b1.png" alt="5.0 stars" width="77px"></mj-image></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" width="50px" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="700">Know what to expect</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="300">Make sure to review the house rules and amenities.</mj-text><mj-text color="#FF5A5F" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="300"><span><a href="https://www.airbnb.com">View House Rules & Manual</a></span></mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" width="50px" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-group><mj-column width="15%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/57s6q59c_dollar_sign_small-1b3b20b329165157d970e14352f53ab5.png" width="40px"></mj-image></mj-column><mj-column width="85%"><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="700">Earn up to $95</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="300">Share your personal invite link and earn up to $95 for every friend who completes a qualifying reservation.</mj-text><mj-text color="#FF5A5F" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700"><span><a href="https://www.airbnb.com">Invite Friends</a></span></mj-text></mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="32px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="700">Find unique things to do in San Francisco</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="16px" padding-left="0px" font-weight="300">Experiences are activities led by local experts that go beyond typical tours or classes.</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="32px" padding-left="16px" background-color="#FEFEFE"><mj-column padding-right="8px" width="50%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/jxxos4fo_e86c7a92-e541-4b6b-90e3-739e9f423d5f.jpg" alt="Food meets bike tour" width="274px" href="https://www.airbnb.com/experiences/75951"></mj-image><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="8px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="400">A food meets bike tour of SF's culinary capital</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="15px" line-height="22px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">4-hour experience</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="15px" line-height="22px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700"><span><a href="https://www.airbnb.com/experiences/75951">See details ›</a></span></mj-text></mj-column><mj-column padding-left="8px" width="50%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/jxxos4fo_e86c7a92-e541-4b6b-90e3-739e9f423d5f.jpg" alt="Taste sake in a brewery" width="274px" href="https://www.airbnb.com/experiences/40564"></mj-image><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="18px" line-height="1.4" padding="10px 25px" padding-top="8px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="400">Taste sake in a brewery paired with pickles and chocolate</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="15px" line-height="22px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="300">2-hour experience</mj-text><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="15px" line-height="22px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700"><span><a href="https://www.airbnb.com/experiences/40564">See details ›</a></span></mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-divider border-width="1px" border-color="#CACACA" padding="10px 25px" padding-top="20px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="16px" padding-bottom="0px" padding-left="16px" background-color="#FEFEFE"><mj-column><mj-text color="#484848" font-family="Circular, Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="700">C