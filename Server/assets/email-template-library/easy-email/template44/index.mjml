<mjml>
  <mj-head>
    <mj-style>.mjbody a, .mjbody a:hover, .mjbody a:active, .mjbody a[href], .mjbody a[href]:hover, .mjbody a[href]:active {color: inherit;text-decoration: underline}</mj-style>
    <mj-breakpoint width="480px" />
    <mj-font name="SofiaPro" href="https://fonts.googleapis.com/css2?family=Sofia+Sans:wght@400;500;600;700&display=swap" />
  </mj-head>
  <mj-body width="680px" background-color="#F5F5F5" css-class="mjbody">
    <mj-section background-repeat="no-repeat" padding="20px 0" padding-top="15px" background-color="#F5F5F5"><mj-column><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/r2st533u_original.png" alt="hers" width="80px" href="https://www.forhers.com"></mj-image></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="40px" padding-right="30px" padding-bottom="0px" padding-left="30px" background-color="#FFFFFF" border-radius="20px"><mj-column><mj-text align="center" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="115px" letter-spacing="-1px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px" font-weight="500"><span style="color:#91DFC4;">I</span><span style="color:#8ADDC6;">t</span><span style="color:#8ADDC6;">'</span><span style="color:#7ED8C9;">s</span>&nbsp;<span style="color:#71D2CE;">s</span><span style="color:#6DCAD2;">o</span><span style="color:#6BC4D5;">o</span><span style="color:#69BED9;">n</span></mj-text><mj-text align="center" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="24px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="20px" padding-bottom="30px" padding-left="20px">Way to start a healthy habit. Your order's in the works, but there's more to explore in the meantime.</mj-text><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/hat272f8_hers-hero.jpg" alt="hers products" width="612px" href="#"></mj-image></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-bottom="0px"><mj-column><mj-spacer height="0px" padding-top="0px" padding-bottom="0px" padding-left="0px" padding-right="0px"></mj-spacer></mj-column></mj-section><mj-section padding="20px 0" padding-right="30px" padding-left="30px"><mj-group vertical-align="middle"><mj-column vertical-align="middle" width="50%"><mj-text font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="26px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-left="0px" font-weight="400">Order details</mj-text></mj-column><mj-column vertical-align="middle" width="50%"><mj-text align="right" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px"><span><a href="#">ORDER_ID</a></span></mj-text></mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="30px" padding-bottom="0px" padding-left="30px" background-color="#FFFFFF"><mj-column><mj-text color="#757575" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px">Items ordered:</mj-text><mj-text font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="30px" padding-left="0px">Detox Scalp Scrub</mj-text><mj-divider border-width="1px" border-color="#D2D3D2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="30px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="30px" padding-bottom="40px" padding-left="30px" background-color="#FFFFFF" border-radius="0 0 20px 20px"><mj-group><mj-column width="50%"><mj-text color="#757575" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px">Total charge:</mj-text><mj-text color="#757575" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-right="0px" padding-bottom="0px" padding-left="0px">Payment method:</mj-text><mj-text color="#757575" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-right="0px" padding-bottom="0px" padding-left="0px">Date paid:</mj-text></mj-column><mj-column width="50%"><mj-text align="right" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px">$44.00</mj-text><mj-text align="right" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-right="0px" padding-bottom="0px" padding-left="0px">Visa*6500</mj-text><mj-text align="right" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-right="0px" padding-bottom="0px" padding-left="0px">10/5/23</mj-text></mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-bottom="0px"><mj-column><mj-spacer height="0px" padding-top="0px" padding-bottom="0px" padding-left="0px" padding-right="0px"></mj-spacer></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-bottom="0px" background-color="#FFFFFF" border-radius="20px"><mj-column width="50%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/2hnfjbdd_original.jpg" alt="hers app" width="340px" href="#" border-radius="20px 0 0 20px"></mj-image></mj-column><mj-column vertical-align="middle" padding-top="40px" padding-right="30px" padding-bottom="40px" padding-left="30px" width="50%"><mj-text font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="26px" line-height="1.3" letter-spacing="-0.5px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-left="0px" font-weight="400">A world of wellness</mj-text><mj-text font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.5" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px">Get ahead of your health goals with free programs and content, right from the app.</mj-text><mj-button align="left" background-color="#000000" border="1px solid #AAAAAA" border-radius="100px" color="#FFFFFF" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="17px" font-weight="600" line-height="50px" inner-padding="0px 30px 0px 30px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" href="#" width="100%" height="50px">Get the app</mj-button></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="50px" padding-bottom="0px" background-color="#F5F5F5"><mj-column><mj-text align="center" color="#1F1F1F" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="19px" padding-left="0px" font-weight="600">Healthcare that feels like self-care</mj-text><mj-social border-radius="0px" font-family="Arial, sans-serif" font-size="0px" icon-size="48px" mode="horizontal" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px"><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" href="https://www.facebook.com/wearehers" alt="Facebook" icon-size="48px" icon-height="48px" background-color="#F5F5F5" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/85nnldry_original.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://twitter.com/wearehers" alt="Twitter" icon-size="48px" icon-height="48px" background-color="#F5F5F5" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/c103084l_original.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://www.instagram.com/hers/" alt="Instagram" icon-size="48px" icon-height="48px" background-color="#F5F5F5" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/6vekzw96_original.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://www.tiktok.com/@hers" alt="TikTok" icon-size="48px" icon-height="48px" background-color="#F5F5F5" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/uupj8vs4_original.png"></mj-social-element></mj-social></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="40px" background-color="#F5F5F5"><mj-column><mj-text align="center" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="12px" line-height="15px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-left="0px">© 2026 Hims, Inc.<br />2269 Chestnut Street #523 | San Francisco | CA 94123</mj-text><mj-text align="center" font-family="'SofiaPro', 'Helvetica Neue', Helvetica, Arial, sans-serif" font-size="12px" line-height="15px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px"><span><a href="https://www.forhers.com/privacy-policy">Privacy Policy</a></span> |&nbsp;<span><a href="https://www.forhers.com/terms-and-conditions">Terms of Service</a></span></mj-text></mj-column></mj-section>
