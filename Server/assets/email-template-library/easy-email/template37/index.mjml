<mjml>
  <mj-head>
    <mj-style>.mjbody a, .mjbody a:hover, .mjbody a:active, .mjbody a[href], .mjbody a[href]:hover, .mjbody a[href]:active {color: inherit;text-decoration: underline}</mj-style>
    <mj-breakpoint width="480px" />
    <mj-font name="Figtree" href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap" />
  </mj-head>
  <mj-body width="600px" background-color="#F2F5FF" css-class="mjbody">
    <mj-section background-repeat="no-repeat" padding="20px 0" padding-top="17px" padding-right="15px" padding-bottom="17px" padding-left="15px" background-color="#FFFFFF"><mj-column><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/s2sm8h3k_App-Icon.png" alt="Calm Logo" width="47px" href="https://www.calm.com"></mj-image></mj-column></mj-section><mj-section background-repeat="no-repeat" background-size="cover" background-position="center top" padding="20px 0" padding-top="30px" padding-right="20px" padding-bottom="130px" padding-left="20px" background-color="#1D3358" background-url="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/daifmu7q_Hero-BG4.png"><mj-column><mj-text align="center" color="#FFFFFF" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="11px" line-height="16px" letter-spacing="1.7px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px" font-weight="600"><span style="background-color:#141473;border:1px solid #FFFFFF;border-radius:50px;padding:5px 20px;display:inline-block;text-transform:uppercase;">Exclusive Partnership Offers</span></mj-text><mj-text align="center" color="#FFFFFF" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="42px" line-height="46px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px" font-weight="400">More Ways to Access Calm</mj-text><mj-text align="center" color="#FFFFFF" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="18px" line-height="28px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="400">Unlock exclusive offers and partner experiences designed to support your mindfulness journey.</mj-text></mj-column></mj-section><mj-wrapper padding="20px 0px" padding-top="0px" padding-right="15px" padding-bottom="30px" padding-left="15px" background-color="#1D3358"><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="7px" padding-bottom="7px"><mj-column><mj-spacer height="1px" padding-top="0px" padding-bottom="0px" padding-left="0px" padding-right="0px"></mj-spacer></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="10px" padding-right="10px" padding-bottom="10px" padding-left="10px" background-color="#FFFFFF" border-radius="10px"><mj-column vertical-align="middle" width="35%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/id52mctb_Disney.png" alt="Calm and Disney+ Perks" width="175px" border-radius="8px" href="https://www.calm.com/disney" fluid-on-mobile="true"></mj-image></mj-column><mj-column vertical-align="middle" padding-left="10px" width="65%"><mj-text color="#333333" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="18px" line-height="28px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="600">Calm and Disney+ Perks</mj-text><mj-text color="#717171" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="14px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="400">Disney+ subscribers can redeem a 6-month free trial to Calm Premium¹. Enjoy the full Calm library, including Sleep Stories, meditations, and soundscapes from your favorite Disney Princesses.</mj-text><mj-text color="#555BE4" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700"><span><a href="https://www.calm.com/disney">Redeem Now →</a></span></mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="7px" padding-bottom="7px"><mj-column><mj-spacer height="1px" padding-top="0px" padding-bottom="0px" padding-left="0px" padding-right="0px"></mj-spacer></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="10px" padding-right="10px" padding-bottom="10px" padding-left="10px" background-color="#FFFFFF" border-radius="10px"><mj-column vertical-align="middle" width="35%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/bz0cdjd4_Sweat.png" alt="Calm + Sweat" width="175px" border-radius="8px" href="https://www.calm.com/sweat" fluid-on-mobile="true"></mj-image></mj-column><mj-column vertical-align="middle" padding-left="10px" width="65%"><mj-text color="#333333" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="18px" line-height="28px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="600">Calm + Sweat: Calm mind. Strong body.</mj-text><mj-text color="#717171" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="14px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="400">Sweat members can get a 6-month free trial to Calm Premium². Pause and take a breath with Calm's library of Sleep Stories, meditations, and soundscapes.</mj-text><mj-text color="#555BE4" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700"><span><a href="https://www.calm.com/sweat">Redeem Now →</a></span></mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="7px" padding-bottom="7px"><mj-column><mj-spacer height="1px" padding-top="0px" padding-bottom="0px" padding-left="0px" padding-right="0px"></mj-spacer></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="10px" padding-right="10px" padding-bottom="10px" padding-left="10px" background-color="#FFFFFF" border-radius="10px"><mj-column vertical-align="middle" width="35%"><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/cgr76jni_Delta.png" alt="Calm for Delta Business Travelers" width="175px" border-radius="8px" href="https://www.calm.com/delta" fluid-on-mobile="true"></mj-image></mj-column><mj-column vertical-align="middle" padding-left="10px" width="65%"><mj-text color="#333333" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="18px" line-height="28px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="600">Calm for Delta Business Travelers</mj-text><mj-text color="#717171" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="14px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="400">Delta Business Travelers can get a 1-month free trial to Calm Premium³ plus an exclusive 50% off for the first 12 months. Pause and take a breath with Calm's library.</mj-text><mj-text color="#555BE4" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700"><span><a href="https://www.calm.com/delta">Redeem Now →</a></span></mj-text></mj-column></mj-section></mj-wrapper><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="30px" padding-right="30px" padding-bottom="0px" padding-left="30px" background-color="#FFFFFF"><mj-column><mj-divider border-width="1px" border-color="#D8D8D8" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider><mj-text align="center" color="#717171" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="10px" line-height="16px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="400">¹ Disney+ offer valid for new Calm users.&nbsp;<span><a href="#">Terms and conditions apply</a></span>.</mj-text><mj-text align="center" color="#717171" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="10px" line-height="16px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="400">² Sweat offer valid for Sweat members.&nbsp;<span><a href="https://sweat.com/terms-of-use">Terms and conditions apply</a></span>.</mj-text><mj-text align="center" color="#717171" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="10px" line-height="16px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px" font-weight="400">³ Delta offer valid for Business Travelers.&nbsp;<span><a href="#">Terms & Conditions Apply</a></span>.</mj-text><mj-divider border-width="1px" border-color="#D8D8D8" width="375px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px"></mj-divider></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="20px" padding-left="20px" background-color="#FFFFFF"><mj-column><mj-social font-family="Arial, sans-serif" font-size="0px" icon-size="53px" mode="horizontal" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" icon-height="49px"><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" href="https://www.instagram.com/calm" alt="Instagram" icon-size="53px" icon-height="49px" background-color="#FFFFFF" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/6wbkp8i0_Social_Insta.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://www.facebook.com/calm" alt="Facebook" icon-size="53px" icon-height="49px" background-color="#FFFFFF" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/iludi483_Social_Facebook.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://www.tiktok.com/@calm" alt="Tik Tok" icon-size="53px" icon-height="49px" background-color="#FFFFFF" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/0e49084i_Social_Tik-Tok.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://www.linkedin.com/company/calm" alt="Linkedin" icon-size="53px" icon-height="49px" background-color="#FFFFFF" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/wkm81n4v_Social_Linked.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://www.threads.net/@calm" alt="Threads" icon-size="53px" icon-height="49px" background-color="#FFFFFF" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/mdib1yst_Social_Threads.png"></mj-social-element></mj-social></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="20px" padding-left="20px" background-color="#FFFFFF"><mj-group><mj-column padding-right="8px" padding-left="8px" width="50%"><mj-image align="right" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/wb3sgsus_App-Store.png" alt="Download on the App Store" width="127px" href="https://apps.apple.com/app/calm"></mj-image></mj-column><mj-column padding-right="8px" padding-left="8px" width="50%"><mj-image align="left" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/d3qtmya0_Google-Play.png" alt="Get it on Google Play" width="127px" href="https://play.google.com/store/apps/details?id=com.calm.android"></mj-image></mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="30px" padding-bottom="30px" padding-left="30px" background-color="#FFFFFF"><mj-column><mj-text align="center" color="#6D7278" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="14px" line-height="15px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px" font-weight="400">Have a question? Visit our&nbsp;<span><a href="https://help.calm.com">Help Center</a></span></mj-text><mj-text align="center" color="#6D7278" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="14px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px" font-weight="400">This email was sent to hello@SmilesDavis.yeah as a registered user of Calm.com, Inc. 555 Bryant Street, Suite 262, Palo Alto, CA 94301</mj-text><mj-text align="center" color="#389FE6" font-family="Figtree, 'Google Sans', Arial, sans-serif" font-size="14px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="600"><span><a href="#">Unsubscribe from email offers</a></span> |&nbsp;<span><a href="#">View email in browser</a></span></mj-text></mj-column></mj-section>
  </mj-body>
</mjml>