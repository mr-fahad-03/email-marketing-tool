<mjml>
  <mj-head>
    <mj-style>.mjbody a, .mjbody a:hover, .mjbody a:active, .mjbody a[href], .mjbody a[href]:hover, .mjbody a[href]:active {color: inherit;text-decoration: underline}</mj-style>
    <mj-breakpoint width="480px" />
  </mj-head>
  <mj-body width="700px" background-color="#d6d6d5" css-class="mjbody">
    <mj-section background-repeat="no-repeat" padding-top="32px" padding-bottom="0px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#e8e8e8"><mj-group><mj-column width="70%">

          <mj-image align="left" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/swe0g4n4_t11gdmxv_7id5k66p_uber-logo.png" alt="Uber" width="94px"></mj-image>

        </mj-column><mj-column width="30%">

          <mj-text align="right" color="#4b4b4b" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="12px" line-height="16px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Nov 28, 2025</mj-text>

          <mj-text align="right" color="#4b4b4b" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="12px" line-height="16px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">8:32 AM</mj-text>

        </mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding-top="24px" padding-bottom="32px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#e8e8e8"><mj-column padding-right="16px" padding-left="15px" width="70%">

        <mj-text color="#000" font-family="UberMoveBold, Arial, sans-serif" font-size="44px" line-height="52px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="16px" padding-left="0px" font-weight="700">Thanks for purchasing an Uber Gift, Smiles Davis</mj-text>

        <mj-text color="#000" font-family="UberMoveTextRegular, Arial, sans-serif" font-size="18px" line-height="28px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="400">They're going to love it. Check your order details below.</mj-text>

      </mj-column><mj-column vertical-align="bottom" width="30%">

        <mj-image align="right" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/kbvxvq4m_7z7935zt_lp1753c2_uber-gift.png" alt="Uber Gift" width="160px"></mj-image>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="32px" padding-bottom="0px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-column width="50%">

        <mj-text color="#000" font-family="UberMoveBold, Arial, sans-serif" font-size="32px" line-height="40px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700">Total</mj-text>

      </mj-column><mj-column width="50%">

        <mj-text align="right" color="#000" font-family="UberMoveBold, Arial, sans-serif" font-size="32px" line-height="40px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700">$425.00</mj-text>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="24px" padding-bottom="0px" padding-left="64px" padding-right="64px" padding="20px 0" background-color="#ffffff"><mj-column>

        <mj-divider border-width="1px" border-color="#f3f3f3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px"></mj-divider>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="15px" padding-bottom="15px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-column width="50%">

        <mj-text color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Gift Card Amount</mj-text>

      </mj-column><mj-column width="50%">

        <mj-text align="right" color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">$500.00</mj-text>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="0px" padding-bottom="15px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-column width="50%">

        <mj-text color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Gift card purchase discount</mj-text>

      </mj-column><mj-column width="50%">

        <mj-text align="right" color="#080" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500" css-class="fare-green">-$75.00</mj-text>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="0px" padding-bottom="16px" padding-left="64px" padding-right="64px" padding="20px 0" background-color="#ffffff"><mj-column>

        <mj-divider border-width="1px" border-color="#f3f3f3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px"></mj-divider>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="16px" padding-bottom="8px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-column>

        <mj-text color="#000" font-family="UberMoveBold, Arial, sans-serif" font-size="24px" line-height="32px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700">Payments</mj-text>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="12px" padding-bottom="12px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-group><mj-column width="20%">

          <mj-image height="32px" padding="10px 25px" padding-top="0px" padding-right="18px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/phj3o93z_jhgxl95k_8k5851nl_mastercard_3x.png" alt="Mastercard" width="35px"></mj-image>

        </mj-column><mj-column width="45%">

