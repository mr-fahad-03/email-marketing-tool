          <mj-text color="#4b4b4b" font-family="UberMoveTextRegular, Arial, sans-serif" font-size="14px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="400">Nov 28, 2025 8:32 AM</mj-text>

        </mj-column><mj-column width="33.333333333333336%">

          <mj-text align="right" color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">$425.00</mj-text>

        </mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding-top="0px" padding-bottom="8px" padding-left="64px" padding-right="64px" padding="20px 0" background-color="#ffffff"><mj-column>

        <mj-divider border-width="1px" border-color="#f3f3f3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px"></mj-divider>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="16px" padding-bottom="16px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-column>

        <mj-text color="#000" font-family="UberMoveBold, Arial, sans-serif" font-size="24px" line-height="32px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="700">Additional information</mj-text>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="10px" padding-bottom="10px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-group><mj-column width="40%">

          <mj-text color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Gift from</mj-text>

        </mj-column><mj-column width="60%">

          <mj-text align="right" color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Smiles Davis</mj-text>

        </mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding-top="0px" padding-bottom="0px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-group><mj-column width="40%">

          <mj-text color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Gift to</mj-text>

        </mj-column><mj-column width="60%">

          <mj-text align="right" color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="16px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" font-weight="500">Really Good Emails</mj-text>

        </mj-column></mj-group></mj-section><mj-section background-repeat="no-repeat" padding-top="16px" padding-bottom="16px" padding-left="64px" padding-right="64px" padding="20px 0" background-color="#ffffff"><mj-column>

        <mj-divider border-width="1px" border-color="#f3f3f3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px"></mj-divider>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="16px" padding-bottom="32px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#ffffff"><mj-column padding-top="16px" padding-right="16px" padding-bottom="16px" padding-left="16px" border-radius="16px">

        <mj-text color="#000" font-family="UberMoveBold, Arial, sans-serif" font-size="20px" line-height="28px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="16px" padding-left="0px" font-weight="700">Need help?</mj-text>

        <mj-text color="#000" font-family="UberMoveTextRegular, Arial, sans-serif" font-size="14px" line-height="20px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="24px" padding-left="0px" font-weight="400">Our support team is happy to help with any concern you might have.</mj-text>

        <mj-button background-color="#f3f3f3" border-radius="8px" color="#000" font-family="UberMoveTextMedium, Arial, sans-serif" font-size="14px" font-weight="500" line-height="16px" inner-padding="10px 16px 10px 16px" padding="10px 25px" padding-right="0px" padding-left="0px" href="https://help.uber.com" width="100%"><img src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/rrb7gbtx_l2bz9vs3_wv4rohin_icon_support_email.png" width="20" height="20" style="vertical-align:middle;margin-right:8px;" />Contact support</mj-button>

      </mj-column></mj-section><mj-section background-repeat="no-repeat" padding-top="32px" padding-bottom="32px" padding-left="32px" padding-right="32px" padding="20px 0" background-color="#000000"><mj-column width="50%">

