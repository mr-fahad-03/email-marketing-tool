<mjml>
  <mj-head>
      <mj-style>.mjbody a, .mjbody a:hover, .mjbody a:active, .mjbody a[href], .mjbody a[href]:hover, .mjbody a[href]:active {color: inherit;text-decoration: underline}</mj-style>
    <mj-breakpoint width="480px" />
  </mj-head>
  <mj-body width="600px" background-color="#F5F5F7" css-class="mjbody">
    <mj-section background-repeat="no-repeat" background-size="cover" background-position="center center" padding="20px 0" padding-top="30px" padding-right="20px" padding-bottom="10px" padding-left="20px" background-color="#1C1C1C" background-url="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/4cntxqp0_f5adc1ca-a1cc-4dd8-acaf-0804eda09568.gif"><mj-column><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/eghw14nx_bc7e6153-71a3-4e25-baa2-2fa45ae89c55.png" alt="SHIFT" width="230px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_0"></mj-image><mj-text align="center" color="#FFFFFF" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px">Welcome to the future of walking.</mj-text><mj-text align="center" color="#FFFFFF" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="60px" line-height="1.1" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="8px" padding-left="0px" font-weight="400">Take the next step with&nbsp;<span style="color:#D2F944;">15% off.</span></mj-text><mj-text align="center" color="#FFFFFF" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px">Offer applies automatically.</mj-text><mj-text align="center" color="#FFFFFF" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="12px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="16px" padding-left="0px">Cannot be combined with any other promotions.</mj-text><mj-button background-color="#D2F944" border-radius="50px" color="#000000" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="17px" font-weight="400" line-height="1" inner-padding="15px 25px 15px 25px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_1">Shop Now</mj-button></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="30px" padding-right="20px" padding-bottom="0px" padding-left="20px" background-color="#EFEFEF"><mj-column><mj-text align="center" color="#121212" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="40px" line-height="1.1" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="20px" padding-left="0px" font-weight="400">Your journey begins here.</mj-text></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="10px" padding-bottom="30px" padding-left="10px" background-color="#EFEFEF"><mj-column padding-right="10px" padding-left="10px" width="50%"><mj-text color="#121212" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="400">Moonwalkers Aero</mj-text><mj-text color="#6B6B6B" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="16px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px">Lighter, quieter, and great for urban environments.</mj-text><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/02sb8zrc_2a81f6a1-2499-4af6-960c-79b43cff3892.png" alt="Moonwalkers Aero" width="300px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_2"></mj-image><mj-text font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px">★★★★★</mj-text><mj-text color="#121212" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="2px" padding-left="0px">"Great product. It feels like gliding."</mj-text><mj-text color="#6B6B6B" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="16px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px">Nikolaus O.</mj-text><mj-button align="left" background-color="#D2F944" border-radius="50px" color="#000000" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="17px" font-weight="400" line-height="1" inner-padding="15px 35px 15px 35px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-left="0px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_3">Explore</mj-button></mj-column><mj-column padding-right="10px" padding-left="10px" width="50%"><mj-text color="#121212" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="24px" line-height="1.2" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px" font-weight="400">Moonwalkers</mj-text><mj-text color="#6B6B6B" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="16px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px">Built rugged to handle cracks and uneven terrain.</mj-text><mj-image padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/zrvlj7kz_c6d7afa7-e0d9-45eb-b2e2-e50fa2973bf0.png" alt="Moonwalkers" width="300px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_4"></mj-image><mj-text font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="4px" padding-left="0px">★★★★★</mj-text><mj-text color="#121212" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="18px" line-height="1.3" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="2px" padding-left="0px">"You literally just walk and off you go!!!"</mj-text><mj-text color="#6B6B6B" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="16px" line-height="1.4" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="12px" padding-left="0px">Pamela G.</mj-text><mj-button align="left" background-color="#D2F944" border-radius="50px" color="#000000" font-family="'TTHovesProRegular', Helvetica, Arial, sans-serif" font-size="17px" font-weight="400" line-height="1" inner-padding="15px 35px 15px 35px" padding="10px 25px" padding-top="0px" padding-right="0px" padding-left="0px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_5">Explore</mj-button></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" background-color="#1C1C1C"><mj-column><mj-social border-radius="0px" font-family="Arial, sans-serif" font-size="0px" icon-size="25px" mode="horizontal" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px"><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_6" alt="Facebook" icon-size="25px" icon-height="25px" background-color="#1C1C1C" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/z0mblwtg_d01b0e6f-04c7-4b49-ad44-635bc9ef60e0.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_7" alt="Instagram" icon-size="25px" icon-height="25px" background-color="#1C1C1C" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/fsb8dsvr_a8748eea-07ee-4a9a-bf22-f11fe4cbd92f.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_8" alt="Youtube" icon-size="25px" icon-height="25px" background-color="#1C1C1C" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/c0w8jrcz_9f829475-5044-47df-85b8-0d802857421b.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_9" alt="TikTok" icon-size="25px" icon-height="25px" background-color="#1C1C1C" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/gmbd9hqa_7cd67d02-9e2e-45a7-b584-b8707a6e6e5e.png"></mj-social-element><mj-social-element font-family="Arial, sans-serif" font-size="0px" padding="4px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="8px" href="https://ctrk.klclick1.com/l/01KC54A1DF4YE75W3ZWCQBQ7M9_10" alt="X" icon-size="25px" icon-height="25px" background-color="#1C1C1C" src="https://cdn.shopify.com/s/files/1/0863/8971/9346/files/d4j4hh66_b05760f3-2f86-4be7-9e65-b1ee2f0e0672.png"></mj-social-element></mj-social></mj-column></mj-section><mj-section background-repeat="no-repeat" padding="20px 0" padding-top="0px" padding-right="20px" padding-left="20px" background-color="#1C1C1C"><mj-group><mj-column width="50%"><mj-image align="left" padding="10px 25px" padding-top="0px" padding-right="0px" padding-bottom="0px" padding-left="0px" src="https://cdn.shopify.com/s/files/1/0863/897